# Copy to .env (gitignored). `langgraph dev` loads it automatically.

# Gemini free tier — create a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-key-here

# LLM is a config value: "provider:model" passed to LangChain's init_chat_model.
# Swapping provider needs the matching langchain-* package installed, no code changes.
# Examples: google_genai:gemini-3.1-flash-lite | anthropic:claude-sonnet-4-6 | ollama:qwen3:8b
DQ_AGENT_MODEL=google_genai:gemini-3.1-flash-lite

# Recorded as approved_by when the approval response doesn't supply an identity
# (localhost demo fallback; defaults to the OS user if unset)
#DQ_AGENT_APPROVER=
