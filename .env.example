# Copy to .env (gitignored). `langgraph dev` loads it automatically.

# Branch feat/bedrock-proxy-adapter: the agent's default model is DeptBedrockChat,
# which reaches Bedrock through the internal bedrock-proxy (dwutils.bedrock). These
# two are read by dwutils itself:
BEDROCK_PROXY_URL=https://your-bedrock-proxy.internal
BEDROCK_TOKEN=your-proxy-token

# Bedrock model id passed to the proxy. Run scripts/explore_bedrock.py (or
# bedrock.get_available_models()) at work to confirm the exact ids your account exposes.
# Examples: eu.anthropic.claude-sonnet-4-6 | eu.anthropic.claude-haiku-4-5-20251001-v1:0
DQ_AGENT_MODEL=eu.anthropic.claude-sonnet-4-6

# Recorded as approved_by when the approval response doesn't supply an identity
# (localhost demo fallback; defaults to the OS user if unset)
#DQ_AGENT_APPROVER=
